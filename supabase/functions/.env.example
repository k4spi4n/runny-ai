# Supabase Edge Functions - server-side secrets (MAU)
# Copy thanh `supabase/functions/.env` roi dien key that:
#   cp supabase/functions/.env.example supabase/functions/.env
# Nap khi chay local:
#   supabase functions serve --env-file supabase/functions/.env
# File .env that da duoc .gitignore bo qua - KHONG commit key len git.

# Browser origins allowed to call interactive Edge Functions. Native clients do
# not send Origin. Separate values with commas.
APP_ALLOWED_ORIGINS=https://runny-ai.onrender.com,http://localhost:3000,http://localhost:5173,http://localhost:8080

# --- AI text/chat (function: openrouter) ---
# Provider chinh: Groq (nhanh nho LPU). Fallback: Cerebras -> OpenRouter khi Groq loi/rate-limit.

# Groq (chinh): https://console.groq.com/keys
GROQ_API_KEY=
# (Tuy chon) Ghi de danh sach model Groq, phan tach boi dau phay, theo thu tu uu tien.
# De trong -> dung mac dinh: openai/gpt-oss-120b,llama-3.3-70b-versatile,llama-3.1-8b-instant
# GROQ_MODELS=openai/gpt-oss-120b,llama-3.3-70b-versatile,llama-3.1-8b-instant

# Cerebras (fallback 1): https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
# (Tuy chon) Ghi de danh sach model Cerebras, phan tach boi dau phay, theo thu tu uu tien.
# De trong -> dung mac dinh: zai-glm-4.7
# CEREBRAS_MODELS=zai-glm-4.7
# Cerebras tinh quota token dua tren max_completion_tokens neu co; de trong se dung
# 1024 cho chat thuong va 4096 cho response_format JSON.
# CEREBRAS_CHAT_MAX_COMPLETION_TOKENS=1024
# CEREBRAS_STRUCTURED_MAX_COMPLETION_TOKENS=4096

# OpenRouter (fallback 2): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# (Tuy chon) Ghi de danh sach model fallback mac dinh cua Edge Function.
# Phan tach boi dau phay, theo thu tu uu tien. De trong -> dung danh sach hard-code trong code.
# OPENROUTER_FALLBACK_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free,deepseek/deepseek-chat-v3-0324:free

# --- Guardrails + Paywall quota (function: openrouter) ---
# Chong lam dung & spam API + gate theo tier (trial|paid|free) qua RPC check_ai_access.
# Tat ca TUY CHON - de trong se dung mac dinh trong code.
# Rate-limit theo tung user (can migration ai_rate_limit + SUPABASE_SERVICE_ROLE_KEY,
# bien nay duoc Supabase tu inject khi deploy/serve nen KHONG can dien o day).
# AI_MAX_PER_MIN=8           # cap/phut/user cho tier trial|paid
# AI_MAX_PER_DAY=30          # cap/ngay/user cho tier trial|paid
# AI_FREE_MAX_PER_MIN=3      # cap/phut/user cho tier free (chi chat; plan/food bi khoa)
# AI_FREE_MAX_PER_DAY=5      # cap/ngay/user cho tier free
# AI_MAX_MESSAGES=40         # so tin nhan toi da trong 1 yeu cau
# AI_MAX_MESSAGE_CHARS=4000  # do dai toi da cua 1 tin nhan
# AI_MAX_TOTAL_CHARS=16000   # tong do dai noi dung toi da trong 1 yeu cau
# AI_PROVIDER_TIMEOUT_MS=25000
# AI_TOTAL_TIMEOUT_MS=55000
# AI_STREAM_IDLE_TIMEOUT_MS=20000
#
# Model overrides are server-owned and scoped per recognized feature, for
# example:
# AI_ACTIVITY_INSIGHT_GROQ_MODELS=llama-3.1-8b-instant
# AI_TRAINING_PLAN_GROQ_MODELS=openai/gpt-oss-120b
# Secret >= 32 ky tu cho Dashboard cron goi training-plan-worker.
TRAINING_PLAN_WORKER_TOKEN=

# --- Thanh toan PayOS (functions: payos-create-payment, payos-webhook) ---
# Lay tu PayOS dashboard (Kenh thanh toan -> API). CHECKSUM_KEY la BI MAT, dung
# de ky request va xac thuc chu ky webhook.
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# URL goc cua app (returnUrl/cancelUrl). De trong -> mac dinh https://runny-ai.onrender.com/
# APP_BASE_URL=https://runny-ai.onrender.com/
# PAYOS_PROVIDER_TIMEOUT_MS=12000

# --- Weather + AQI (function: weather) ---
# Can it nhat 1 trong 2 key duoi day.
# WAQI (AQI chinh): https://aqicn.org/data-platform/token/
WAQI_API_KEY=
# OpenWeatherMap (thoi tiet + AQI du phong): https://openweathermap.org/api
OPENWEATHER_API_KEY=

# --- Strava (functions: strava_oauth, strava_webhook) ---
# Tao app tai https://www.strava.com/settings/api. CLIENT_SECRET la BI MAT.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# OAuth callback registered in Strava.  Keep it server-side so the client only
# receives a short-lived authorization URL created by the Edge Function.
STRAVA_REDIRECT_URI=http://localhost:3000/
# Token tu dat, dung khi dang ky webhook subscription (GET verify).
# Bat buoc toi thieu 16 ky tu; KHONG dung gia tri mau/cong khai.
STRAVA_VERIFY_TOKEN=
# ID Strava tra ve sau khi tao webhook subscription. Moi POST phai khop ID nay.
STRAVA_SUBSCRIPTION_ID=
# Secret >= 32 ky tu cho Dashboard cron goi strava-webhook-worker.
STRAVA_WEBHOOK_WORKER_TOKEN=
# STRAVA_PROVIDER_TIMEOUT_MS=12000
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY duoc Supabase tu inject khi deploy,
# KHONG can dien o day.

# --- Food recognition (function: food-recognition) ---
# Nhan dien mon an bang model vision cua Groq (dung lai GROQ_API_KEY o tren).
# Production fail-closed neu thieu provider/key.
# FOOD_RECOGNITION_PROVIDER=groq
# Mock chi duoc bat ro rang cho local development:
# FOOD_RECOGNITION_PROVIDER=mock
# FOOD_RECOGNITION_ALLOW_MOCK=true
# (Tuy chon) Ghi de model vision. De trong -> mac dinh: qwen/qwen3.6-27b
# FOOD_RECOGNITION_MODEL=qwen/qwen3.6-27b
# (Tuy chon) Han muc rieng cho nhan dien anh (chat hon chat vi vision nang hon).
# Dung chung bo dem ai_rate_limit theo user voi function openrouter.
# FOOD_AI_MAX_PER_MIN=6      # so anh toi da / phut / user
# FOOD_AI_MAX_PER_DAY=50     # so anh toi da / ngay / user
# FOOD_PROVIDER_TIMEOUT_MS=20000
# WEATHER_PROVIDER_TIMEOUT_MS=8000
