# --- Supabase Configuration ---
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# --- AI Configuration (OpenRouter) ---
# Primary AI provider through OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- AI Configuration (Google Gemini Fallback) ---
# Direct fallback if OpenRouter is unavailable
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# --- Food Recognition ---
# Current backend implementation uses a mock service abstraction.
# Switch this later when a real Vision provider is implemented in the Edge Function.
FOOD_RECOGNITION_PROVIDER=mock
# FOOD_VISION_API_KEY=your_future_vision_provider_key

# --- Strava Integration ---
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3000/
STRAVA_VERIFY_TOKEN=your_strava_webhook_verify_token

# --- Other Services ---
OPENWEATHER_API_KEY=your_openweather_api_key
