# --- Supabase Configuration ---
# Required for client-backend communications
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# --- AI Configuration (Edge Function Proxy) ---
# AI operations are securely proxied via Supabase Edge Functions.
# Primary provider: Groq (fast). Fallback: OpenRouter when Groq errors/rate-limits.
# DO NOT define API keys here to avoid client-side exposure.
# Set API keys on your Supabase server using:
# `supabase secrets set GROQ_API_KEY=your_key`        # primary
# `supabase secrets set OPENROUTER_API_KEY=your_key`  # fallback
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# (Tuy chon) Danh sach model fallback, phan tach boi dau phay.
# Neu dat bien nay, client se gui mang `models` va OpenRouter tu nhay sang
# model ke tiep khi 1 model bi rate-limit/loi -> giam manh ti le that bai.
# De trong -> backend (Edge Function) van tu ap dung danh sach fallback mac dinh.
# OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free,deepseek/deepseek-chat-v3-0324:free

# --- Food Recognition ---
# Nhan dien mon an chay tren Edge Function `food-recognition` (Groq vision).
# Provider/model/API key la SERVER secret (xem supabase/functions/.env.example) -
# KHONG cau hinh o day vi .env client duoc bundle vao web build.
#
# Tuy chon (chi cho DEV): tra ve du lieu gia khi Edge Function khong san co.
# Mac dinh TAT (de loi that tu server hien thi cho nguoi dung). Bat: =true
# FOOD_RECOGNITION_MOCK=false

# --- Strava Integration ---
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3000/
STRAVA_VERIFY_TOKEN=your_strava_webhook_verify_token

# --- Weather Services (Edge Function Proxy) ---
# Weather APIs are securely proxied via Supabase Edge Functions.
# Set the OpenWeather key on your Supabase server using:
# `supabase secrets set OPENWEATHER_API_KEY=your_key`
